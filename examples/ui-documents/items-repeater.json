          "item_heights": {
            "record-00001": 72,
            "record-00004": 64,
            "record-00006": 60
          },
          "overscan_rows": 2,
          "placeholders": true
        },
        "property_bindings": {
          "viewport": "records_viewport",
          "selected": "selected_record"
        },
        "action_bindings": {
          "viewport_change": "records_viewport_changed",
          "select": "record_selected"
