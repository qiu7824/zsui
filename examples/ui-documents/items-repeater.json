      "padding_token": "page_padding",
      "gap_token": "content_gap"
    },
    "children": [
      {
        "id": "records-title",
        "component": "text",
        "properties": {
          "text": "虚拟化记录 / Virtualized records",
          "text_role": "title",
          "weight": "semibold"
        }
      },
      {
        "id": "records-description",
        "component": "text",
        "layout": { "width": 820 },
        "properties": {
          "text": "ItemsRepeater 只实例化当前窗口需要的行；稳定节点 ID 映射到全局索引，可变行高、选择和视口仍由应用显式持有。 / ItemsRepeater materializes only the required window while stable node IDs map to application-owned indices, variable heights and controlled viewport state.",
          "wrap": "word"
        }
      },
      {
        "id": "records",
        "component": "items_repeater",
        "layout": { "width": 820, "height": 420 },
        "properties": {
