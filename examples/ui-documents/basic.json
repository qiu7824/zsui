{
  "schema_version": 1,
  "root": {
    "id": "root",
    "component": "stack",
    "layout": {
      "direction": "vertical",
      "padding_token": "page_padding",
      "gap_token": "content_gap"
    },
    "children": [
      {
        "id": "title",
        "component": "text",
        "property_bindings": {
          "text": "window_title"
        },
        "theme_tokens": {
          "foreground": "text.primary"
        },
        "accessibility": {
          "role": "heading",
          "label": "Document title"
        }
      },
      {
        "id": "save-button",
        "component": "button",
        "properties": {
          "label": "Save",
          "enabled": true
        },
        "action_bindings": {
          "click": "save"
        }
      }
    ]
  }
}
