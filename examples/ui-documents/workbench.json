                "pinned": true
              },
              {
                "id": "thread-proof",
                "title": "三平台原生验收",
                "subtitle": "Windows · macOS · Linux",
                "unread": true
              }
            ]
          }
        ],
        "footer_actions": [
          { "id": "settings", "label": "设置 / Settings", "icon": "Settings" }
