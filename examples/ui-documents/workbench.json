                }
              ]
            },
            {
              "id": "assistant-result",
              "role": "assistant",
              "author": "ZSUI",
              "blocks": [
                {
                  "kind": "paragraph",
                  "text": "四个部件已组合为一个保留式工作台表面；结构、状态和事件保持平台中立，布局、字体、图标和绘制由目标平台配置决定。"
                },
                {
                  "kind": "tool",
                  "title": "UiDocument 结构验证",
                  "summary": "校验稳定 ID、子组件顺序、动作载荷和受控状态",
                  "status": "succeeded"
                },
                {
                  "kind": "code",
                  "language": "rust",
                  "code": "WorkbenchShell\n  MessageTimeline\n  Composer\n  InspectorPanel\n\nTyped state\nTyped events\nNative draw plan\nStable widget identity"
                },
                {
                  "kind": "notice",
                  "text": "Viewer 仅用于开发热重载；发布应用直接嵌入同一份已验证文档。",
                  "level": "info"
                }
              ],
              "actions": [
                { "id": "copy", "label": "复制 / Copy", "icon": "Copy" },
                { "id": "retry", "label": "重试 / Retry", "icon": "Retry" }
              ]
            },
            {
              "id": "system-proof",
              "role": "system",
              "blocks": [
                {
                  "kind": "notice",
                  "text": "真实点击、文字输入和滚动由共享 View 事件路由处理。",
                  "level": "success"
                }
              ]
            }
          ]
        },
        "property_bindings": {
          "offset_y": "timeline_offset"
        },
        "action_bindings": {
          "message_action": "message_action_invoked",
          "scroll": "timeline_scrolled"
        }
      },
      {
        "id": "composer",
        "component": "composer",
        "properties": {
